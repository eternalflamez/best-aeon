# Copy to `.env` and fill in values. See README.md for where to get each one.
# Never commit `.env`.

ENVIRONMENT=develop

# --- Discord bot tokens ---
TOKEN=
MANAGER_TOKEN=
LEAF_TOKEN=

# --- Gemini ---
GEMINI_KEY=

# --- Buyer management ---
PRICE_UPDATE_URL=
# Invite code only (not full URL). Key = INVITE_<discord_guild_id>
INVITE_1248337933413650614=
INVITE_1507831199513444402=

